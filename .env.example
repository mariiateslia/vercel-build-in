# FsCopilot environment

# Vercel AI Gateway key — enables the LIVE disclosure review.
# Without it, /api/review returns the mock (x-fscopilot-mode: mock) so demos still work.
# Get one at https://vercel.com/ai-gateway  (or run `eve link` to pull from a linked Vercel project).
AI_GATEWAY_API_KEY=

# Optional: model override (gateway id). Defaults to anthropic/claude-haiku-4.5,
# which works on free AI Gateway credits. Switch to a premium model after a paid
# top-up, e.g.:
# FSCOPILOT_MODEL=anthropic/claude-sonnet-4.6

# Optional: lock CORS on /api/review to the deployed v0 UI origin (defaults to *).
# FSCOPILOT_ALLOWED_ORIGIN=https://your-v0-app.vercel.app
